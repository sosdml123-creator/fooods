{
  "version": 2,
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/app-ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/app-ads.txt",
      "destination": "/api/index.js"
    },
    {
      "source": "/app-ads",
      "destination": "/api/index.js"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    },
    {
      "source": "/authorize",
      "destination": "/api/index.js"
    },
    {
      "source": "/privacy",
      "destination": "/api/index.js"
    },
    {
      "source": "/privacy.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/terms",
      "destination": "/api/index.js"
    },
    {
      "source": "/terms.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/landing",
      "destination": "/api/index.js"
    },
    {
      "source": "/landing.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|health|admin|app-ads|robots|privacy|terms|landing).*)",
      "destination": "/index.html"
    }
  ]
}
