rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. 관리자 권한 확인 헬퍼 함수
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super'
        );
    }

    // 2. users 컬렉션 보안 규칙 (가입 전 중복체크를 위해 read 허용)
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followingList'])
      );
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 3. posts (레시피) 컬렉션 보안 규칙
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && !(postId in ['1', '2', '3']) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if (request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount', 'scrappedBy', 'comments'])
      )) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
      );
    }

    // 4. community_posts (커뮤니티) 컬렉션 보안 규칙
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if (request.auth != null && !(postId in ['cp1', 'cp2', 'cp3', 'cp4', 'cp5'])) || isAdmin();
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if (request.auth != null && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount', 'scrappedBy', 'comments'])
      )) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
      );
    }

    // 5. reports (신고 내역) 컬렉션 보안 규칙
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, write: if isAdmin();
    }

    // 6. notices (공지사항) 컬렉션 보안 규칙
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. pushHistory (푸시 이력) 컬렉션 보안 규칙
    match /pushHistory/{pushId} {
      allow read, write: if isAdmin();
    }

    // 8. adminLogs (활동 로그) 컬렉션 보안 규칙
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // 9. settings (시스템 세팅) 컬렉션 보안 규칙
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 10. blocks (차단) 컬렉션 보안 규칙
    match /blocks/{blockId} {
      allow read, write: if request.auth != null;
    }

    // 11. devices 컬렉션 보안 규칙
    match /devices/{deviceFingerprint} {
      allow read, write: if true;
    }

    // 12. dailyStats 컬렉션 보안 규칙
    match /dailyStats/{dateId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
