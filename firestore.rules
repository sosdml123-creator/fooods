rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. 관리자 권한 확인 헬퍼 함수
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 2. users 컬렉션 보안 규칙
    match /users/{userId} {
      // 본인 또는 관리자만 읽기/쓰기 가능
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 3. posts (레시피) 컬렉션 보안 규칙
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && !(postId in ['1', '2', '3']) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if (request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount', 'scrappedBy', 'comments'])
      )) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
      );
    }

    // 4. community_posts (커뮤니티) 컬렉션 보안 규칙
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if (request.auth != null && !(postId in ['cp1', 'cp2', 'cp3', 'cp4', 'cp5'])) || isAdmin();
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if (request.auth != null && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount', 'scrappedBy', 'comments'])
      )) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
      );
    }

    // 5. reports (신고 내역) 컬렉션 보안 규칙
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, write: if isAdmin();
    }
  }
}
