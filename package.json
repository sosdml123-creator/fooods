{
  "name": "foodhouse-app",
  "version": "1.0.0",
  "description": "FoodHouse Mobile Application wrapped with Capacitor",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "build": "node build.js",
    "cap-init": "npx cap init \"플레이팅\" \"com.foodhouse.app\" --web-dir=www",
    "cap-add-android": "npm install @capacitor/android && npx cap add android",
    "cap-add-ios": "npm install @capacitor/ios && npx cap add ios",
    "cap-sync": "node build.js && npx cap sync",
    "open-android": "npx cap open android",
    "open-ios": "npx cap open ios"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@capacitor/core": "^6.0.0",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "qs": "^6.15.2",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
