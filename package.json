{
  "name": "foodhouse-app",
  "version": "1.0.0",
  "description": "FoodHouse Mobile Application wrapped with Capacitor",
  "main": "build.js",
  "scripts": {
    "start": "node-portable\\node-v20.11.0-win-x64\\node.exe server.js",
    "build": "node build.js",
    "cap-init": "npx cap init \"플레이팅\" \"com.foodhouse.app\" --web-dir=www",
    "cap-add-android": "npm install @capacitor/android && npx cap add android",
    "cap-add-ios": "npm install @capacitor/ios && npx cap add ios",
    "cap-sync": "node build.js && npx cap sync",
    "open-android": "npx cap open android",
    "open-ios": "npx cap open ios"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@capacitor/core": "^6.0.0",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
